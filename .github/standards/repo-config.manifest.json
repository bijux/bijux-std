{
  "version": 1,
  "repositories": [
    {
      "name": "bijux-atlas",
      "release_env": [
        {
          "key": "BIJUX_RELEASE_ENABLED",
          "type": "bool",
          "value": true
        },
        {
          "key": "BIJUX_RELEASE_WAIT_FOR_CI_COMMAND",
          "type": "string",
          "value": "make gh-release-wait-for-ci"
        },
        {
          "key": "BIJUX_RELEASE_PLAN_COMMAND",
          "type": "string",
          "value": "make gh-release-plan-github"
        },
        {
          "key": "BIJUX_RELEASE_PREPARE_COMMAND",
          "type": "string",
          "value": ".github/scripts/prepare_release_github.sh"
        },
        {
          "key": "BIJUX_RELEASE_SETUP_RUST",
          "type": "bool",
          "value": true
        },
        {
          "key": "BIJUX_RELEASE_RUST_TOOLCHAIN",
          "type": "string",
          "value": "1.86.0"
        },
        {
          "key": "BIJUX_RELEASE_FILES_MANIFEST",
          "type": "string",
          "value": ".github/release-github.files"
        },
        {
          "key": "BIJUX_RELEASE_NOTES_PATH",
          "type": "string",
          "value": "artifacts/github-release/release-notes.md"
        },
        {
          "key": "BIJUX_RELEASE_DELETE_EXISTING",
          "type": "bool",
          "value": false
        },
        {
          "key": "BIJUX_RELEASE_FAIL_ON_UNMATCHED_FILES",
          "type": "bool",
          "value": true
        },
        {
          "key": "BIJUX_RELEASE_GENERATE_RELEASE_NOTES",
          "type": "bool",
          "value": false
        },
        {
          "key": "BIJUX_RELEASE_ARTIFACTS_ENABLED",
          "type": "bool",
          "value": false
        },
        {
          "key": "BIJUX_CRATES_RELEASE_ENABLED",
          "type": "bool",
          "value": true
        },
        {
          "key": "BIJUX_CRATES_RELEASE_WAIT_FOR_CI_COMMAND",
          "type": "string",
          "value": "make gh-release-wait-for-ci"
        },
        {
          "key": "BIJUX_CRATES_RELEASE_PLAN_COMMAND",
          "type": "string",
          "value": "make gh-release-plan-crates"
        },
        {
          "key": "BIJUX_CRATES_RELEASE_SETUP_RUST",
          "type": "bool",
          "value": true
        },
        {
          "key": "BIJUX_CRATES_RELEASE_RUST_TOOLCHAIN",
          "type": "string",
          "value": "1.86.0"
        },
        {
          "key": "BIJUX_CRATES_RELEASE_VERIFY_TOKEN_COMMAND",
          "type": "string",
          "value": "make gh-release-require-cargo-token"
        },
        {
          "key": "BIJUX_CRATES_RELEASE_PUBLISH_SKIP_EXISTING",
          "type": "bool",
          "value": true
        },
        {
          "key": "BIJUX_CRATES_RELEASE_PUBLISH_COMMAND",
          "type": "string",
          "value": "make publish-rs RUST_PUBLISH_DRY_RUN=0 RUST_PUBLISH_SKIP_EXISTING=1 RUST_PUBLISH_PACKAGES=\"${PACKAGES}\""
        },
        {
          "key": "BIJUX_GHCR_RELEASE_ENABLED",
          "type": "bool",
          "value": false
        },
        {
          "key": "BIJUX_PYPI_ENABLED",
          "type": "bool",
          "value": false
        }
      ],
      "dependabot": {
        "version": 2,
        "updates": [
          {
            "package-ecosystem": "cargo",
            "directory": "/",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": "05:00"
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(deps)"
            },
            "groups": {
              "rust-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "rust-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          },
          {
            "package-ecosystem": "github-actions",
            "directory": "/",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": "05:30"
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(actions)"
            },
            "groups": {
              "github-actions-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "github-actions-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          },
          {
            "package-ecosystem": "npm",
            "directory": "/configs/sources/repository/docs",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": "06:00"
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(docs-deps)"
            },
            "groups": {
              "docs-tooling-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "docs-tooling-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          },
          {
            "package-ecosystem": "pip",
            "directory": "/configs/sources/repository/docs",
            "schedule": {
              "interval": "weekly",
              "day": "monday",
              "time": "06:15"
            },
            "open-pull-requests-limit": 3,
            "commit-message": {
              "prefix": "chore(docs-python)"
            },
            "groups": {
              "docs-python-minor-patch": {
                "update-types": [
                  "minor",
                  "patch"
                ]
              },
              "docs-python-major": {
                "update-types": [
                  "major"
                ]
              }
            }
          }
        ]
      }
    },
